# Single-GPU TensorRT-LLM serving profile for local RTX 4060 class machines.
#
# TRTLLM_MODEL accepts:
#   1. HuggingFace model id, for example Qwen/Qwen2.5-1.5B-Instruct
#   2. local HuggingFace checkpoint directory under ./models
#   3. local TensorRT-LLM engine directory under ./engines
#
# Non-TensorRT model formats are not serving inputs here. Use an HF checkpoint
# or a built TensorRT-LLM engine.

TRTLLM_IMAGE=infra-trtllm:25.06
TRTLLM_CONTAINER=infra-trtllm
TRTLLM_HF_ENDPOINT=https://hf-mirror.com

TRTLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
TRTLLM_MODEL_PATH=
TRTLLM_TOKENIZER=
TRTLLM_EXTRA_OPTIONS=

TRTLLM_HOST=0.0.0.0
TRTLLM_PORT=8000
TRTLLM_GPU_DEVICE=0

TRTLLM_TP_SIZE=1
TRTLLM_PP_SIZE=1
TRTLLM_GPUS_PER_NODE=1

TRTLLM_MAX_BATCH_SIZE=8
TRTLLM_MAX_NUM_TOKENS=4096
TRTLLM_MAX_SEQ_LEN=4096
TRTLLM_KV_CACHE_FREE_GPU_MEMORY_FRACTION=0.75
TRTLLM_NUM_POSTPROCESS_WORKERS=0
TRTLLM_LOG_LEVEL=info
TRTLLM_BENCH_WORKSPACE=/engines/bench
TRTLLM_BENCH_DATASET=/workspace/configs/benchmarks/smoke.jsonl
TRTLLM_BENCH_CONCURRENCY=1
TRTLLM_BENCH_REQUESTS=4
TRTLLM_BENCH_WARMUP=1
TRTLLM_ENGINE_DIR=

# Set to "pytorch" only for debugging model support. Empty means TensorRT-LLM
# C++ executor path, which is the production path.
TRTLLM_BACKEND=
